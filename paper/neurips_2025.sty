% neurips_2025.sty - Minimal NeurIPS 2025 style (preprint mode)
% Replace with official style from https://neurips.cc when available

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{neurips_2025}[2025/01/01 NeurIPS 2025 Style (minimal)]

\newif\if@preprint\@preprintfalse
\DeclareOption{preprint}{\@preprinttrue}
\DeclareOption{final}{}
\DeclareOption{nonatbib}{}
\ProcessOptions\relax

% Page geometry
\RequirePackage[letterpaper,top=1in,bottom=1in,left=1.5in,right=1.5in]{geometry}

% Typography
\RequirePackage{times}
\RequirePackage{natbib}
\bibliographystyle{plainnat}

% Section formatting
\RequirePackage{titlesec}
\titleformat{\section}{\large\bfseries}{\thesection}{1em}{}
\titleformat{\subsection}{\normalsize\bfseries}{\thesubsection}{1em}{}
\titleformat{\subsubsection}{\normalsize\itshape}{\thesubsubsection}{1em}{}

% Line spacing
\linespread{1.05}

% Abstract
\renewenvironment{abstract}{%
  \centerline{\large\bfseries Abstract}%
  \vspace{0.5em}%
  \begin{quote}\small
}{%
  \end{quote}%
  \vspace{1em}%
}

\endinput
